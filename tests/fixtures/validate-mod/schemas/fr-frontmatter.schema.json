{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "title"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]{2,4}-[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string"
    }
  }
}
